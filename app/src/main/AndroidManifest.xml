<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.SavingsWidget">
        <activity
            android:name="com.n0white.n0widgets.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.n0white.n0widgets.SavingsActivity"
            android:exported="true"
            android:label="@string/savings_settings_title"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SavingsWidget" />

        <activity
            android:name="com.n0white.n0widgets.CounterActivity"
            android:exported="true"
            android:label="@string/counter_settings_title"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SavingsWidget" />

        <activity
            android:name="com.n0white.n0widgets.CalendarSettingsActivity"
            android:exported="true"
            android:label="@string/calendar_settings_title"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SavingsWidget" />

        <activity
            android:name="com.n0white.n0widgets.SettingsActivity"
            android:exported="true"
            android:label="@string/settings_title"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SavingsWidget" />

        <activity
            android:name="com.n0white.n0widgets.AboutActivity"
            android:exported="true"
            android:label="@string/about_title"
            android:launchMode="singleTask"
            android:theme="@style/Theme.SavingsWidget" />

        <activity
            android:name="com.n0white.n0widgets.AddAmountActivity"
            android:exported="true"
            android:theme="@style/Theme.Transparent"
            android:excludeFromRecents="true"
            android:taskAffinity="com.n0white.n0widgets.dialog"
            android:launchMode="singleInstance" />

        <receiver
            android:name="com.n0white.n0widgets.ui.widget.SavingsWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_savings_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/savings_widget_info" />
        </receiver>

        <receiver
            android:name="com.n0white.n0widgets.ui.widget.CounterWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_counter_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="com.n0white.n0widgets.ACTION_REFRESH_COUNTER" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/counter_widget_info" />
        </receiver>

        <receiver
            android:name="com.n0white.n0widgets.ui.widget.CalendarWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_calendar_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.CONFIGURATION_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/calendar_widget_info" />
        </receiver>
    </application>

</manifest>
